# Supabase (project URL + anon key from Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Server-only — used by server actions for storage admin operations (cleanup on approval).
# Never expose this to the browser.
SUPABASE_SECRET_KEY=sb_secret_your-key

# OpenAI (server-only)
OPENAI_API_KEY=sk-...
# Optional overrides — defaults are gpt-image-2 (image tool) and gpt-5-mini (orchestrator model).
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_RESPONSES_MODEL=gpt-5-mini

# Base URL of the deployed app, used for Supabase email redirect link
# Local: http://localhost:3000
# Prod:  https://snip.yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (SMTP relay for Supabase auth emails). Get a key at https://resend.com/api-keys
# Note: for `supabase start` to pick this up locally, it must also be set in a plain
# `.env` file at the repo root (Supabase CLI's env() substitution doesn't read .env.local).
RESEND_API_KEY=re_...

# Ameriabank vPOS (server-only). Test host: https://servicestest.ameriabank.am/VPOS
# Production host: https://services.ameriabank.am/VPOS
# ClientID/username/password and the OrderID range come from your Ameriabank
# merchant agreement (test values are in the bank's vPOS testing guide).
AMERIA_API_BASE_URL=https://servicestest.ameriabank.am/VPOS
AMERIA_CLIENT_ID=
AMERIA_USERNAME=
AMERIA_PASSWORD=
AMERIA_ORDER_ID_BASE=0
